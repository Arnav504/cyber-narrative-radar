# Backend environment (copy to .env for local overrides)

# local | production
ENVIRONMENT=local

# SQLite locally; use Postgres in deployment (Railway/Render/Heroku-style URLs OK)
DATABASE_URL=sqlite:///./cyber_narrative_radar.db
# DATABASE_URL=postgresql://user:pass@host:5432/cyber_narrative

# Dashboard origin for CORS
FRONTEND_URL=http://localhost:5173

# Optional comma-separated extra CORS origins
# CORS_ORIGINS=https://extra.example.com

# CLI ingest/score → running API SSE bus (POST /api/events/notify)
# EVENTS_NOTIFY=1
# EVENTS_NOTIFY_URL=http://127.0.0.1:8000/api/events/notify

# Optional live synthetic demo generator (python -m app.tasks.generate_live_demo)
# DEMO_LIVE_INTERVAL_MIN=20
# DEMO_LIVE_INTERVAL_MAX=30
# DEMO_LIVE_BATCH_SIZE=1

# Optional scheduled RSS inside the API process (Week-1 live ingest)
# LIVE_INGEST=1
# LIVE_INGEST_INTERVAL_SECONDS=180
# AUTO_ALERT_MIN_SCORE=45

# Reddit collector (public JSON; optional OAuth app credentials)
# REDDIT_ENABLED=1
# REDDIT_SUBREDDITS=netsec,cybersecurity,blueteamsec
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
