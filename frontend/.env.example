# Backend API origin used by the Vite frontend.
# Local default matches uvicorn on port 8000.
VITE_API_BASE_URL=http://localhost:8000

# Optional: Vite dev-server proxy target (see vite.config.ts).
# VITE_API_PROXY_TARGET=http://localhost:8000

# Optional SSE live notifications (default on). Set to 0 to rely on 15s polling only.
# VITE_LIVE_EVENTS=0
